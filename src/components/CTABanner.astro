---
interface Props {
  title: string;
  subtitle?: string;
  buttonText: string;
  buttonHref: string;
}

const { title, subtitle, buttonText, buttonHref } = Astro.props;
---

<section class="cta">
  <div class="container cta-inner">
    <h2 class="cta-title">{title}</h2>
    {subtitle && <p class="cta-sub">{subtitle}</p>}
    <a class="cta-btn" href={buttonHref}>{buttonText}</a>
  </div>
</section>

<style>
  .cta {
    background: var(--hc-navy);
    padding: 72px 0;
    text-align: center;
  }

  .cta-inner {
    max-width: 680px;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: var(--t-section-size);
    font-weight: 600;
    line-height: 1.15;
    color: var(--hc-white);
    margin-bottom: 12px;
  }

  .cta-sub {
    font-size: var(--t-body-size);
    color: var(--hc-white-80);
    line-height: 1.5;
    margin-bottom: 28px;
  }

  /* pill button */
  .cta-btn {
    display: inline-block;
    background: var(--hc-orange);
    color: var(--hc-white);
    font-family: var(--font-display);
    font-size: var(--t-btn-size);
    font-weight: 600;
    padding: 14px 36px;
    border-radius: var(--r-pill);
    transition: background 0.2s var(--ease-std), transform 0.2s var(--ease-std);
    margin-top: 16px;
  }

  .cta-btn:hover {
    background: var(--hc-orange-deep);
    transform: scale(1.03);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .cta {
      padding: 56px 0;
    }

    .cta-title {
      font-size: 1.75rem;
    }
  }
</style>
