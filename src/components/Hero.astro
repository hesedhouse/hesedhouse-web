---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  dark?: boolean;
  accentWord?: string;
  backgroundImage?: string;
  fullscreen?: boolean;
}

const { eyebrow, title, subtitle, dark = true, accentWord, backgroundImage, fullscreen = false } = Astro.props;

function renderTitle(text: string, accent?: string) {
  if (!accent) return text;
  const idx = text.indexOf(accent);
  if (idx === -1) return text;
  return `${text.slice(0, idx)}<span class="accent">${accent}</span>${text.slice(idx + accent.length)}`;
}

const titleHtml = renderTitle(title, accentWord);
---

<section
  class:list={["hero", { dark, fullscreen }]}
  style={backgroundImage ? `--hero-bg: url(${backgroundImage})` : undefined}
>
  {backgroundImage && <div class="hero-overlay"></div>}
  <div class="container hero-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="title" set:html={titleHtml} />
    {subtitle && <p class="subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--sp-96) 0 72px;
    text-align: center;
    background: var(--bg-page);
    color: var(--fg-primary);
  }

  .hero.dark {
    background: var(--bg-section-dark);
    color: var(--fg-on-dark);
  }

  /* Fullscreen hero with background image */
  .hero.fullscreen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--bg-section-dark);
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.35) 40%,
      rgba(0, 0, 0, 0.50) 100%
    );
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }

  .eyebrow {
    font-size: var(--t-micro-size);
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--hc-orange);
    margin-bottom: 16px;
  }

  .title {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 600;
    line-height: 1.07;
    letter-spacing: -0.5px;
  }

  .fullscreen .title {
    font-size: 4rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .title :global(.accent) {
    color: var(--hc-orange);
  }

  .subtitle {
    font-size: 1.3125rem;
    font-weight: 400;
    line-height: 1.5;
    margin-top: 20px;
    opacity: 0.82;
  }

  .fullscreen .subtitle {
    font-size: 1.375rem;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
  }

  .hero:not(.dark) .subtitle {
    color: var(--fg-secondary);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero {
      padding: 64px 0 48px;
    }

    .hero.fullscreen {
      min-height: 100svh;
      padding: 0 20px;
    }

    .title {
      font-size: 2.25rem;
    }

    .fullscreen .title {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.0625rem;
    }
  }
</style>
