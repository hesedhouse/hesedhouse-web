---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';
---

<PageLayout title="MERCHANDISING" description="트렌드를 읽고, 상품으로 완성합니다">
  <Hero dark title="MERCHANDISING" subtitle="트렌드를 읽고, 상품으로 완성합니다" />

  <section class="service-detail">
    <div class="detail-inner">
      <p class="detail-text">아이디어에서 완제품까지. 기획, 디자인, 샘플링, 생산, 품질관리의 전 과정을 전담합니다.</p>
    </div>
  </section>

  <section class="sub-services">
    <div class="sub-inner">
      <div class="sub-grid">
        <ServiceCard eyebrow="01" title="Product Planning" description="시장 분석 기반 상품 기획 및 라인업 구성" />
        <ServiceCard eyebrow="02" title="Design & Sampling" description="디자인 시안 제작, 샘플 개발 및 승인" />
        <ServiceCard eyebrow="03" title="Production & QC" description="본생산 관리, 품질 검수, 패키징" />
      </div>
    </div>
  </section>

  <CTABanner title="상품 기획부터 생산까지, 함께합니다." subtitle="아이디어를 완제품으로 만들어 드립니다." buttonText="문의하기" buttonHref="/contact" />
</PageLayout>

<style>
  .service-detail { padding: 72px 20px; }
  .detail-inner { max-width: var(--content-max); margin: 0 auto; }
  .detail-text { font-size: 1.3125rem; line-height: 1.5; max-width: 680px; color: var(--hc-ink); }
  .sub-services { padding: 0 20px 72px; }
  .sub-inner { max-width: var(--content-max); margin: 0 auto; }
  .sub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 768px) { .sub-grid { grid-template-columns: 1fr; } }
</style>
