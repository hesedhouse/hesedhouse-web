---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';
---

<PageLayout title="POP-UP OPERATION" description="공간을 브랜드 경험으로 전환합니다">
  <Hero dark title="POP-UP OPERATION" subtitle="공간을 브랜드 경험으로 전환합니다" />

  <section class="service-detail">
    <div class="detail-inner">
      <p class="detail-text">팝업스토어, 전시, 이벤트의 기획부터 시공, 운영, 철수까지 원스톱으로 제공합니다.</p>
    </div>
  </section>

  <section class="sub-services">
    <div class="sub-inner">
      <div class="sub-grid">
        <ServiceCard eyebrow="01" title="Space Planning" description="공간 디자인, 동선 설계, 시공 관리" />
        <ServiceCard eyebrow="02" title="Operations" description="현장 운영, 인력 관리, POS 시스템" />
        <ServiceCard eyebrow="03" title="Event Marketing" description="현장 이벤트, 프로모션, SNS 연동" />
      </div>
    </div>
  </section>

  <CTABanner title="공간이 곧 브랜드입니다." subtitle="기획부터 철수까지, 원스톱으로." buttonText="문의하기" buttonHref="/contact" />
</PageLayout>

<style>
  .service-detail { padding: 72px 20px; }
  .detail-inner { max-width: var(--content-max); margin: 0 auto; }
  .detail-text { font-size: 1.3125rem; line-height: 1.5; max-width: 680px; color: var(--hc-ink); }
  .sub-services { padding: 0 20px 72px; }
  .sub-inner { max-width: var(--content-max); margin: 0 auto; }
  .sub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 768px) { .sub-grid { grid-template-columns: 1fr; } }
</style>
