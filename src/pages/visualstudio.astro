---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';
---

<PageLayout title="VISUAL STUDIO" description="브랜드를 시각으로 완성합니다">
  <Hero dark title="VISUAL STUDIO" subtitle="브랜드를 시각으로 완성합니다" />

  <section class="service-detail">
    <div class="detail-inner">
      <p class="detail-text">사진, 영상, 그래픽 디자인까지. 브랜드의 비주얼 아이덴티티를 구축합니다.</p>
    </div>
  </section>

  <section class="sub-services">
    <div class="sub-inner">
      <div class="sub-grid">
        <ServiceCard eyebrow="01" title="Photography" description="제품 촬영, 룩북, 공간 촬영" />
        <ServiceCard eyebrow="02" title="Video Production" description="홍보 영상, 바이럴 콘텐츠, 인터뷰" />
        <ServiceCard eyebrow="03" title="Graphic Design" description="패키지 디자인, 인쇄물, 디지털 에셋" />
      </div>
    </div>
  </section>

  <CTABanner title="비주얼로 브랜드를 말합니다." subtitle="촬영부터 디자인까지." buttonText="문의하기" buttonHref="/contact" />
</PageLayout>

<style>
  .service-detail { padding: 72px 20px; }
  .detail-inner { max-width: var(--content-max); margin: 0 auto; }
  .detail-text { font-size: 1.3125rem; line-height: 1.5; max-width: 680px; color: var(--hc-ink); }
  .sub-services { padding: 0 20px 72px; }
  .sub-inner { max-width: var(--content-max); margin: 0 auto; }
  .sub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 768px) { .sub-grid { grid-template-columns: 1fr; } }
</style>
